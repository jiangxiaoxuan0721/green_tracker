# =============================================================================
# 环境配置示例文件 - Green Tracker 项目
# =============================================================================
# 使用说明：
# 1. 复制此文件为 .env 并根据实际情况填写配置
# 2. 请勿将包含敏感信息的 .env 文件提交到版本控制系统

# =============================================================================
# 应用基础配置
# =============================================================================

# 应用环境 (development, production)
NODE_ENV=development

# 前端服务器端口
PORT=3010

# 前端API请求基础URL
# 注意：这里使用API_HOST和API_PORT的组合，避免硬编码
VITE_API_BASE_URL=http://localhost:6130

# =============================================================================
# 前端环境变量配置 (Vite)
# =============================================================================

# MinIO前端配置
VITE_MINIO_ENDPOINT=your-domain.com
VITE_MINIO_PORT=9100
VITE_MINIO_BUCKET=your-bucket-name
VITE_MINIO_SECURE=false
VITE_MINIO_PUBLIC_URL=http://your-domain.com:9100/your-bucket-name

# API超时配置
VITE_API_TIMEOUT=30000

# 图像处理配置
VITE_THUMBNAIL_SIZE=150
VITE_IMAGE_LAZY_LOADING=true
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,gif,webp,bmp

# 缓存配置
VITE_THUMBNAIL_CACHE_TTL=3600
VITE_IMAGE_CACHE_LIMIT=100

# 性能配置
VITE_ENABLE_VIRTUAL_SCROLL=false
VITE_PAGE_SIZE=20
VITE_MAX_CONCURRENT_REQUESTS=5


# 允许的主机列表（逗号分隔）
VITE_ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# 后端API配置
# =============================================================================

# API服务器主机配置
API_HOST=0.0.0.0
API_PORT=6130

# JWT认证配置
# 注意：在生产环境中请使用强随机密钥（至少32位）
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# =============================================================================
# 数据库配置 (PostgreSQL)
# =============================================================================

DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# 元数据库名称（固定，用于存储用户、数据库等元数据）
META_DB_NAME=green_tracker_meta
TEMPLATE_DB_NAME=green_tracker_template
USER_DB_PREFIX=green_tracker_user_

# 超级用户配置（用于创建数据库）
DB_SUPERUSER=postgres
DB_SUPERPASSWORD=your_superuser_password

# 数据库连接池配置（可选）
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# =============================================================================
# 对象存储配置 (MinIO)
# =============================================================================

# MinIO连接配置
MINIO_BUCKET_NAME=your-bucket-name
MINIO_ENDPOINT=your-domain.com
MINIO_PORT=9100
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# MinIO安全配置（生产环境建议启用https）
MINIO_SECURE=false

# =============================================================================
# 日志配置
# =============================================================================

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 日志文件路径（可选，默认为控制台输出）
LOG_FILE_PATH=logs

# =============================================================================
# CORS配置
# =============================================================================

# 允许的源（逗号分隔，请根据实际部署域名修改）
CORS_ORIGINS=http://localhost:3010,http://127.0.0.1:3010

# 允许的方法（逗号分隔）
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS

# 允许的头部（逗号分隔）
CORS_HEADERS=Content-Type,Authorization

# =============================================================================
# 文件上传配置
# =============================================================================

# 最大文件上传大小（字节，默认10MB）
MAX_UPLOAD_SIZE=10485760

# 允许的文件类型（逗号分隔）
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,txt,zip,xls,xlsx
