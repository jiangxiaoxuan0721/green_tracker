# =============================================================================
# 前端环境变量配置示例文件 (Vite)
# =============================================================================
# 使用说明：
# 1. 复制此文件为 .env 并根据实际情况填写配置
# 2. 请勿将包含敏感信息的 .env 文件提交到版本控制系统

# =============================================================================
# 应用基础配置
# =============================================================================

# 应用环境 (development, production)
NODE_ENV=development

# =============================================================================
# MinIO对象存储配置
# =============================================================================

# MinIO服务连接配置
VITE_MINIO_ENDPOINT=your-minio-domain.com
VITE_MINIO_PORT=9100
VITE_MINIO_BUCKET=your-bucket-name
VITE_MINIO_SECURE=false

# MinIO公开访问URL（用于图片直接访问）
VITE_MINIO_PUBLIC_URL=http://your-minio-domain.com:9100/your-bucket-name

# =============================================================================
# API接口配置
# =============================================================================

# 后端API基础URL
VITE_API_BASE_URL=http://localhost:6130

# API请求超时时间（毫秒）
VITE_API_TIMEOUT=30000

# =============================================================================
# 图像处理配置
# =============================================================================

# 缩略图尺寸（像素）
VITE_THUMBNAIL_SIZE=150

# 是否启用图像懒加载
VITE_IMAGE_LAZY_LOADING=true

# 最大文件上传大小（字节，默认10MB）
VITE_MAX_FILE_SIZE=10485760

# 允许的图像格式（逗号分隔）
VITE_ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,gif,webp,bmp

# =============================================================================
# 缓存配置
# =============================================================================

# 缩略图缓存有效期（秒）
VITE_THUMBNAIL_CACHE_TTL=3600

# 图像缓存限制数量
VITE_IMAGE_CACHE_LIMIT=100

# =============================================================================
# 性能优化配置
# =============================================================================

# 是否启用虚拟滚动（大数据量列表优化）
VITE_ENABLE_VIRTUAL_SCROLL=false

# 分页大小
VITE_PAGE_SIZE=20

# 最大并发请求数
VITE_MAX_CONCURRENT_REQUESTS=5

# =============================================================================
# 开发环境配置
# =============================================================================

# 默认登录凭据（仅用于开发测试，生产环境请移除）
VITE_DEFAULT_USERNAME=admin
VITE_DEFAULT_PASSWORD=123456

# 允许的主机列表（逗号分隔，用于CORS和安全检查）
VITE_ALLOWED_HOSTS=localhost,127.0.0.1
